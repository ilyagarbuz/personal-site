---
import ResumeLayout from "../layouts/ResumeLayout.astro";
import ResumeContent from "../components/ResumeContent.astro";
import { profile, profilePageTitle } from "../data/profile";
import { experience } from "../data/experience";
import { projects } from "../data/projects";
import { toolkit } from "../data/toolkit";
import { resumeUiEn } from "../data/resume-ui.en";
---

<ResumeLayout title={`Résumé — ${profilePageTitle()}`} lang="en">
  <ResumeContent
    profile={profile}
    experience={experience}
    projects={projects}
    toolkit={toolkit}
    labels={resumeUiEn}
    locale="en"
  />
</ResumeLayout>
