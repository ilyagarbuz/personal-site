---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Button from "../../components/Button.astro";
import Card from "../../components/Card.astro";
import { ArrowLeft } from "@lucide/astro";
import { getCollection } from "astro:content";
import "../../styles/home.css";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(d: Date) {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout title="Blog — Ilya Garbuz" description="Thoughts on web development, tools, and learning.">
  <div class="page">
    <Header />
    <main id="main" class="container section">
      <nav aria-label="Breadcrumb">
        <a href="/" class="blog-back">
          <ArrowLeft size={18} stroke-width={1.75} aria-hidden="true" />
          Home
        </a>
      </nav>
      <header class="blog-index-header">
        <h1>Blog</h1>
        <p class="blog-index-sub">
          Thoughts on web development, tools, and things I'm learning.
        </p>
      </header>
      <div class="blog-preview">
        {
          posts.map((post) => (
            <Card class="blog-preview__card">
              <p class="blog-card__meta">
                {formatDate(post.data.pubDate)} · {post.data.readingTime} min read
              </p>
              <h2 class="blog-list-title">{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="blog-card__actions">
                <Button href={`/blog/${post.slug}/`} variant="ghost">
                  Read more
                </Button>
              </div>
            </Card>
          ))
        }
      </div>
    </main>
    <Footer />
  </div>
</BaseLayout>

<style>
  .blog-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    border-radius: 0.5rem;
    padding: 0.35rem 0.5rem;
    margin-left: -0.5rem;
    transition: background-color 0.15s ease;
  }

  .blog-back:hover {
    background: var(--color-surface);
    color: var(--color-accent);
  }

  .blog-index-header h1 {
    margin: 0 0 0.5rem;
    font-size: clamp(1.85rem, 4vw, 2.35rem);
    letter-spacing: -0.03em;
  }

  .blog-index-sub {
    margin: 0 0 2rem;
    max-width: 48ch;
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.55;
  }

  .blog-list-title {
    margin: 0 0 0.45rem;
    font-size: 1.15rem;
    font-weight: 650;
    letter-spacing: -0.02em;
  }
</style>
