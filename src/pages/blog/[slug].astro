---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { ArrowLeft } from "@lucide/astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(d: Date) {
  return d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout
  title={`${post.data.title} — Ilya Garbuz`}
  description={post.data.description}
>
  <div class="page">
    <Header />
    <main id="main" class="container section article-wrap">
      <nav aria-label="Breadcrumb">
        <a href="/blog/" class="article-back">
          <ArrowLeft size={18} stroke-width={1.75} aria-hidden="true" />
          Blog
        </a>
      </nav>
      <article class="prose article">
        <header class="article-header">
          <h1>{post.data.title}</h1>
          <p class="article-meta">
            <time datetime={post.data.pubDate.toISOString()}
              >{formatDate(post.data.pubDate)}</time
            >
            <span class="article-meta__sep" aria-hidden="true">·</span>
            <span>{post.data.readingTime} min read</span>
          </p>
        </header>
        {
          post.data.coverImage ? (
            <figure class="article-cover">
              <Image
                src={post.data.coverImage}
                alt=""
                width="850"
                height="450"
                loading="eager"
              />
            </figure>
          ) : null
        }
        <Content />
      </article>
    </main>
    <Footer />
  </div>
</BaseLayout>

<style>
  .article-wrap {
    padding-bottom: 3rem;
  }

  .article-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1.75rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    border-radius: 0.5rem;
    padding: 0.35rem 0.5rem;
    margin-left: -0.5rem;
    transition: background-color 0.15s ease;
  }

  .article-back:hover {
    background: var(--color-surface);
    color: var(--color-accent);
  }

  .article-header h1 {
    margin: 0 0 0.65rem;
    font-size: clamp(1.85rem, 4.5vw, 2.5rem);
    letter-spacing: -0.03em;
    line-height: 1.15;
    max-width: 100%;
  }

  .article-meta {
    margin: 0 0 1.5rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .article-meta__sep {
    margin-inline: 0.35rem;
  }

  .article-cover {
    margin: 0 0 1.5rem;
  }

  .article-cover img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 0.9rem;
    border: 1px solid var(--color-border);
  }

  .article.prose {
    max-width: 100%;
  }
</style>
