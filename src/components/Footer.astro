---
import "./Footer.css";
import { GitFork, Link2, Mail } from "@lucide/astro";
import { social } from "../data/social";
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <p class="site-footer__copy">© 2026 Ilya Garbuz</p>
    <nav class="site-footer__links" aria-label="Social links">
      <a
        class="site-footer__link"
        href={social.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile"
      >
        <GitFork size={20} stroke-width={1.75} aria-hidden="true" />
      </a>
      <a
        class="site-footer__link"
        href={social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn profile"
      >
        <Link2 size={20} stroke-width={1.75} aria-hidden="true" />
      </a>
      <a class="site-footer__link" href={social.email} aria-label="Send email">
        <Mail size={20} stroke-width={1.75} aria-hidden="true" />
      </a>
    </nav>
  </div>
</footer>
